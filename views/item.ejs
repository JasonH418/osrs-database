        <!--          <section class="drop-source-info">-->
        <!--            <h3 class="drop-source-name">Abyssal Sire</h3>-->
        <!--            <p class="drop-source-level">Combat Level: 350</p>-->
        <!--          </section>-->
        <!--          <p class="drop-source-rate">1/100</p>-->
        <!--        </section>-->
        <!--      </section>-->
        <!--    </section>-->
    </section>
</main>

<%- include("partials/footer") %>
